# ────────────────────────────────────────────
# Radar Transparência — Variáveis de Ambiente
# ────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# ── API Keys ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Banco de dados ────────────────────────────
# SQLite (padrão para desenvolvimento):
DATABASE_URL=sqlite:///./radar_transparencia.db
# PostgreSQL (para produção):
# DATABASE_URL=postgresql://user:pass@host:5432/radar_transparencia

# ── Configurações de execução ─────────────────
BATCH_SIZE=10
MAX_CONCURRENT_REQUESTS=5
RATE_LIMIT_DELAY_SECONDS=2
LLM_MODEL=claude-sonnet-4-20250514

# ── Querido Diário API ────────────────────────
QUERIDO_DIARIO_API_URL=https://queridodiario.ok.org.br/api

# ── Logs ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=radar_transparencia.log

# ── Playwright (para portais com JavaScript) ──
# Instale com: pip install "radar-transparencia[browser]" && playwright install chromium
USE_PLAYWRIGHT=false
